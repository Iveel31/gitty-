#include<bits/stdc++.h>
using namespace std;
int main(){
    int t;
    cin >>t ;
    while(t--){
        int n;
        cin >> n;
        vector<int>a(n);
        map<int,int>b;
        for(int = 0 ;i < n; i++){
            cin >> a[i];
            b[a[i]]++;
        }
        
    }
    return 0;
}